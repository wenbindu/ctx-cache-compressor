# Copy this file to .env.local for local development.
# Then load it into your current shell:
#
#   cp .env.example .env.local
#   source scripts/source_env.sh .env.local
#
# Keep real secrets in .env.local or your shell profile, not in Git-tracked files.

# Canonical key for any OpenAI-compatible upstream provider.
OPENAI_API_KEY=

# Optional runtime settings.
RUST_LOG=info
CTX_CACHE_COMPRESSOR_CONFIG_FILE=config.toml

# Optional config override examples:
# CTX_CACHE_COMPRESSOR__SERVER__PORT=8080
# CTX_CACHE_COMPRESSOR__COMPRESSION__EVERY_N_TURNS=5
